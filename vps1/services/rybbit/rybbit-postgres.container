[Unit]
Description=Rybbit PostgreSQL

[Container]
ContainerName=rybbit-postgres
Image=docker.io/postgres:17.4
Pull=newer
PublishPort=127.0.0.1:52721:5432
EnvironmentFile=./env/postgres.env
Volume=/home/core/containers-git/vps1/volumes/rybbit-postgres:/var/lib/postgresql/data:Z

[Service]
TimeoutStartSec=15min
ExecStartPre=/usr/bin/mkdir -p /home/core/containers-git/vps1/volumes/rybbit-postgres

[Install]
WantedBy=default.target
