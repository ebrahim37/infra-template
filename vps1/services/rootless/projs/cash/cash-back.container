[Unit]
Description=Cash backend

[Container]
ContainerName=cash-back
Image=docker.io/oven/bun:alpine
Pull=newer
PublishPort=127.0.0.1:20077:20077
Volume=/home/core/containers-git/vps1/projs/cash/back:/src:ro,Z
Volume=/home/core/containers-git/vps1/services/rootless/projs/cash/entrypoint.sh:/usr/local/bin/entrypoint.sh:ro,Z
Volume=/home/core/containers-git/vps1/volumes/projs-cash-node:/app/node_modules:Z
WorkingDir=/app
Exec=/usr/local/bin/entrypoint.sh

[Service]
TimeoutStartSec=15min
ExecStartPre=/usr/bin/mkdir -p /home/core/containers-git/vps1/volumes/projs-cash-node

[Install]
WantedBy=default.target
