[Unit]
Description=Tailscale client
Requires=user@1000.service
Wants=network-online.target
After=network-online.target user@1000.service

[Container]
ContainerName=tailscale-client
Image=docker.io/tailscale/tailscale
Pull=newer
Network=host
AddDevice=/dev/net/tun
AddCapability=NET_ADMIN NET_RAW
Volume=/home/core/containers-git/vps1/volumes/tailscale-client-data:/var/lib/tailscale:Z
Environment="TS_AUTHKEY={{ tailscale_auth_key }}"
Environment=TS_STATE_DIR=/var/lib/tailscale
Environment=TS_USERSPACE=false
Environment=TS_AUTH_ONCE=true
Environment=TS_HOSTNAME={{ hostname }}
Environment="TS_EXTRA_ARGS=--login-server=https://headscale.{{ base_domain }} --advertise-exit-node"

[Service]
TimeoutStartSec=15min
# Headscale is a rootless unit, so start it through core's user manager.
ExecStartPre=/usr/sbin/runuser -u core -- /usr/bin/env XDG_RUNTIME_DIR=/run/user/1000 /usr/bin/systemctl --user start headscale.service
ExecStartPre=install -d -o core -g core -m 0755 /home/core/containers-git/vps1/volumes/tailscale-client-data

[Install]
WantedBy=multi-user.target
