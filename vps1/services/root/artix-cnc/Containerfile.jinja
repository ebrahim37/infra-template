FROM docker.io/artixlinux/artixlinux:base-dinit

RUN pacman -Syu --noconfirm --needed \
	base-devel \
	btop \
	eza \
	git \
	less \
	ncdu \
	neovim \
	npm \
	openssh \
	plocate \
	podman \
	python \
	ripgrep \
	screen \
	unzip \
	vim

RUN groupadd -g 1000 ebrahim \
	&& useradd -m -u 1000 -g 1000 -G wheel -s /bin/bash ebrahim \
	&& printf '%%wheel ALL=(ALL:ALL) NOPASSWD: ALL\n' > /etc/sudoers.d/10-wheel-nopasswd

RUN printf '%s\n' \
		'type = internal' \
		'depends-on = sshd' \
	> /etc/dinit.d/boot \
	&& printf '%s\n' \
		'type = process' \
		'command = /bin/sh -c "cp /host/etc/ssh/ssh_host_* /etc/ssh/ 2>/dev/null || true; chmod 0600 /etc/ssh/ssh_host_*_key 2>/dev/null || true; exec /usr/bin/sshd -D -e"' \
		'log-type = buffer' \
		'log-buffer-size = 65536' \
		> /etc/dinit.d/sshd \
	&& install -d -m 0755 /etc/ssh/sshd_config.d \
	&& printf '%s\n' \
		'Port 222' \
		'PermitRootLogin no' \
		'PubkeyAuthentication yes' \
		'AuthenticationMethods publickey' \
		'PasswordAuthentication no' \
		'KbdInteractiveAuthentication no' \
		> /etc/ssh/sshd_config.d/10-artix-cnc.conf \
	&& ssh-keygen -A

RUN install -d -m 0700 -o ebrahim -g ebrahim /home/ebrahim/.ssh

COPY shared/vimrc /etc/vimrc
COPY --chown=ebrahim:ebrahim shared/ssh_config /home/ebrahim/.ssh/config
COPY --chown=ebrahim:ebrahim shared/home/ /home/ebrahim/
COPY --chown=ebrahim:ebrahim home/ /home/ebrahim/
RUN install -d -m 0700 -o ebrahim -g ebrahim /home/ebrahim/.ssh \
	&& printf '%s\n' '{{ ssh_authorized_key }}' > /home/ebrahim/.ssh/authorized_keys \
	&& chown ebrahim:ebrahim /home/ebrahim/.ssh/authorized_keys \
	&& chmod 0600 /home/ebrahim/.ssh/authorized_keys /home/ebrahim/.ssh/config \
	&& install -d -m 0755 -o ebrahim -g ebrahim /home/ebrahim/ssl \
	&& ln -s /host/home/core/infra-template /home/ebrahim/infra-template \
	&& ln -s /host/home/core/infra-template/vps1/volumes/caddy-data/caddy/certificates/acme-v02.api.letsencrypt.org-directory/wildcard_.ebra.dev/wildcard_.ebra.dev.crt /home/ebrahim/ssl/fullchain.pem \
	&& ln -s /host/home/core/infra-template/vps1/volumes/caddy-data/caddy/certificates/acme-v02.api.letsencrypt.org-directory/wildcard_.ebra.dev/wildcard_.ebra.dev.key /home/ebrahim/ssl/privkey.pem \
	&& chown -h ebrahim:ebrahim /home/ebrahim/ssl/fullchain.pem /home/ebrahim/ssl/privkey.pem \
	&& chmod +x /home/ebrahim/scripts/* \
	&& rm -f /home/ebrahim/.bash_logout

RUN croc_tmp=$(mktemp -d) \
	&& croc_version=$(curl -fsSIL -o /dev/null -w '%{url_effective}' https://github.com/schollz/croc/releases/latest | sed 's#.*/##') \
	&& curl -fsSL "https://github.com/schollz/croc/releases/download/${croc_version}/croc_${croc_version}_Linux-64bit.tar.gz" \
		| tar -xz -C "$croc_tmp" \
	&& install -D -m 0755 -o ebrahim -g ebrahim "$croc_tmp/croc" /home/ebrahim/scripts/croc-bin \
	&& rm -rf "$croc_tmp"

RUN git clone --depth=1 https://aur.archlinux.org/yay-bin.git /tmp/yay-bin \
	&& chown -R ebrahim:ebrahim /tmp/yay-bin \
	&& su - ebrahim -c 'cd /tmp/yay-bin && makepkg -i --noconfirm --cleanbuild --clean' \
	&& rm -rf /tmp/yay-bin \
	&& su - ebrahim -c '/home/ebrahim/scripts/ya -Yc && /home/ebrahim/scripts/ya -Scc' \
	&& su - ebrahim -c 'curl -fsSL https://bun.sh/install | bash' \
	&& su - ebrahim -c 'bun install -g http-server @openai/codex'

STOPSIGNAL SIGTERM

ENTRYPOINT ["/sbin/dinit", "--services-dir", "/etc/dinit.d", "boot"]
