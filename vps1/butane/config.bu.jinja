variant: fcos
version: 1.7.0

passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - {{ ssh_authorized_key }}

systemd:
  units:
    - name: install-host-packages.service
      enabled: true
      contents: |
        [Unit]
        Description=Layer host packages with rpm-ostree
        Wants=network-online.target
        After=network-online.target
        Before=zincati.service
        ConditionPathExists=!/var/lib/%N.stamp

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStart=/usr/bin/rpm-ostree install -y --allow-inactive qemu-guest-agent git-core
        ExecStart=/bin/touch /var/lib/%N.stamp
        ExecStart=/bin/systemctl --no-block reboot

        [Install]
        WantedBy=multi-user.target
    - name: qemu-guest-agent.service
      enabled: true
    - name: clone-containers-repo.service
      enabled: true
      contents: |
        [Unit]
        Description=Clone containers git repo for core user
        Wants=network-online.target
        After=network-online.target install-host-packages.service
        ConditionPathExists=/usr/bin/git
        ConditionPathExists=!/var/home/core/containers-git/.git

        [Service]
        Type=oneshot
        User=core
        Group=core
        WorkingDirectory=/var/home/core
        ExecStart=/usr/bin/git clone "{{ containers_git_repo }}" /var/home/core/containers-git

        [Install]
        WantedBy=multi-user.target

storage:
  files:
    - path: /etc/hostname
      overwrite: true
      mode: 0644
      contents:
        inline: {{ hostname }}
    - path: /etc/hosts
      overwrite: true
      mode: 0644
      contents:
        inline: |
          127.0.0.1        localhost
          ::1              localhost
          {{ public_ipv4 }}   {{ hostname }}.{{ base_domain }}
    - path: /etc/sysctl.d/90-containers.conf
      mode: 0644
      contents:
        inline: |
          net.ipv4.ip_forward = 1
          net.ipv6.conf.all.forwarding = 1
          net.ipv4.ip_unprivileged_port_start = 53
    - path: /etc/systemd/zram-generator.conf
      mode: 0644
      contents:
        inline: |
          # this config file enables a /dev/zram0 device with the default settings
          [zram0]
    - path: /etc/profile.d/systemd-pager.sh
      mode: 0644
      contents:
        inline: |
          export SYSTEMD_PAGER=cat
    - path: /etc/subuid
      overwrite: true
      mode: 0644
      contents:
        inline: |
          core:100000:65536
    - path: /etc/subgid
      overwrite: true
      mode: 0644
      contents:
        inline: |
          core:100000:65536
    # starts core's user systemd manager without an interactive login
    - path: /var/lib/systemd/linger/core
      mode: 0644

  directories:
    - path: /etc/containers
      mode: 0755
    - path: /etc/containers/systemd
      mode: 0755
    - path: /var/home/core/.config
      mode: 0755
      user:
        name: core
      group:
        name: core
    - path: /var/home/core/.config/containers
      mode: 0755
      user:
        name: core
      group:
        name: core

  links:
    # services-dist/ is generated by /home/core/containers-git/vps1/build-containers.sh after provisioning
    - path: /etc/containers/systemd/vps1-root
      overwrite: true
      target: /var/home/core/containers-git/vps1/services-dist/root
    - path: /var/home/core/.config/containers/systemd
      overwrite: true
      target: /var/home/core/containers-git/vps1/services-dist/rootless
